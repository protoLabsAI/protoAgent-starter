{
  "name": "proto-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run dev --filter=packages/server & pnpm run dev --filter=packages/app",
    "build": "pnpm run build --recursive --if-present",
    "typecheck": "pnpm run typecheck --recursive --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.2"
}
