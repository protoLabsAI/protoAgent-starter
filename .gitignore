# Dependencies
node_modules/

# Build outputs
dist/

# Turborepo cache
.turbo/

# Environment files
.env
.env.local
.env.*.local

# OS files
.DS_Store

# Automaker - runtime lock file (PID lock, changes every agent run)
.automaker-lock

# Automaker - runtime artifacts and user-generated content
.automaker/**/agent-output.md
.automaker/**/images/
.automaker/**/authority/
.automaker/**/analysis.json
.automaker/**/*.bak*
.automaker/**/handoff-*.json
.automaker/.backups/
.automaker/events/
.automaker/execution-state.json
.automaker/notifications.json
.automaker/categories.json
.automaker/context/context-metadata.json
.automaker/worktrees/
.automaker/worktree-init.sh
.automaker/prd-output.json

# Feature board state — per-instance, synced via CRDT mesh (not git)
.automaker/features/
.automaker/archive/

# Runtime data — never git-track
.automaker/crdt/
.automaker/trajectory/
.automaker/ledger/
.automaker/recovery/
.automaker/checkpoints/
.automaker/actionable-items.json
.automaker/hitl-forms.json
.automaker/content/
**/.automaker/knowledge.db
**/.automaker/knowledge.db-shm
**/.automaker/knowledge.db-wal
.automaker/knowledge-eval.jsonl
.automaker/ceremony-log.jsonl
.automaker/quarantine/

# Instance-specific — each machine starts fresh
.automaker/settings.json

# Runtime state files — now stored in DATA_DIR (not git-tracked)
.automaker/metrics/dora.json
.automaker/metrics/error-budget.json
.automaker/lead-engineer-sessions.json
apps/server/.automaker/pr-tracking.json
.automaker/projects/*/ceremony-state.json

# Track shared knowledge (agent learning, skills, context, spec, projects)
!.automaker/context/
!.automaker/skills/
!.automaker/memory/
!.automaker/projects/
!.automaker/spec.md
