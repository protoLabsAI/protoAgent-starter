{
  "name": "proto-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./packages/server\" --filter \"./packages/app\" run dev",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.2"
}
